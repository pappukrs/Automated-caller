# Copy this file to ".env" and fill in your values.

# Port your local server listens on.
PORT=3000

# What the caller hears. Keep the "this call is recorded" line.
GREETING=Hello, and thank you for calling. Please note this call is recorded. Please leave your message after the beep, and press the hash key when you are done.

# Plivo Speak voice (Amazon Polly). Indian English options: Polly.Aditi (female), Polly.Raveena (female).
VOICE=Polly.Aditi

# Recording limits (Phase 1).
RECORD_MAX_LENGTH=120   # max seconds to record
RECORD_TIMEOUT=10       # seconds of silence before auto-stopping

# Public URL of this server (e.g. your ngrok https URL). If unset, it's derived
# from the incoming request's Host header. Set it if Plivo gets a wrong action URL.
PUBLIC_URL=

# --- Plivo credentials (from https://console.plivo.com) ---
# Phase 1 uses these to download the recording (Basic auth on the RecordUrl).
# Phase 4 reuses them (plus PLIVO_NUMBER) to send SMS appointment confirmations.
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_NUMBER=   # your Plivo number in E.164, e.g. +91XXXXXXXXXX (SMS sender)

# --- Speech-to-text (Phase 2) ---
# Which provider to use: "deepgram" (default) or "sarvam" (best for Indian languages).
STT_PROVIDER=deepgram

# Deepgram (https://console.deepgram.com)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=multi   # "multi" = Hindi/English code-switching; or "hi" / "en"

# Sarvam (https://dashboard.sarvam.ai)
SARVAM_API_KEY=
SARVAM_MODEL=saarika:v2
SARVAM_LANGUAGE=unknown   # "unknown" = auto-detect; or e.g. "hi-IN"

# --- Phase 3: live AI conversation ---
# Claude (the brain). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8   # for lower call latency you can try claude-haiku-4-5
AGENT_SYSTEM_PROMPT=You are a friendly phone receptionist. Reply with ONLY spoken words, one or two short sentences, asking one question at a time.

# ElevenLabs (text-to-speech). Get a key + voice id at https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Phase 3 reuses DEEPGRAM_API_KEY (above) for live streaming speech-to-text.
