# Copy this file to ".env" and fill in your values.

# Port your local server listens on.
PORT=3000

# What the caller hears. Keep the "this call is recorded" line.
GREETING=Hello, and thank you for calling. Please note this call is recorded for quality purposes. Our automated assistant is being set up and will be with you shortly. Goodbye.

# Plivo Speak voice (Amazon Polly). Indian English options: Polly.Aditi (female), Polly.Raveena (female).
VOICE=Polly.Aditi

# --- Plivo credentials (from https://console.plivo.com) ---
# Not used in Phase 0 (no outbound API calls yet), but add them now so later phases work.
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
